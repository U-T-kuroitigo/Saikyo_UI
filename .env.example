# ===== 非機密（初期値は compose 側にもあるが、上書きしたい人はここで設定） =====
APP_PORT=8080
MYSQL_HOST_PORT=33306
TZ=Asia/Tokyo
MYSQL_CHARSET=utf8mb4
MYSQL_COLLATION=utf8mb4_0900_ai_ci

# ===== MySQL（機密） =====
# 初回起動時に使用されます。空だと起動失敗するので実値を入れてください。
MYSQL_ROOT_PASSWORD={{change_here}}
MYSQL_DATABASE={{change_here}}
MYSQL_USER={{change_here}}
MYSQL_PASSWORD={{change_here}}

# ===== GoアプリのDB接続 =====
# Docker内からDBへはホスト名 "db"（サービス名）で到達します
Server=db
Port=3306
User=${MYSQL_USER}
Password=${MYSQL_PASSWORD}
Database=${MYSQL_DATABASE}

# 外部API用
STORE_ID={{store_id_here}}